{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "server=${DATABASE_HOST};port=${DATABASE_PORT};database=${DATABASE_NAME};user=${DATABASE_USER};password=${DATABASE_PASSWORD}"
  },
  "Jwt": {
    "Secret": "MediTrackSensorPlatformSecretKey2026Minimum32Chars!",
    "Issuer": "MediTrackSensor",
    "Audience": "MediTrackSensorClients",
    "ExpirationDays": "7"
  }
}